{
    "name": "Tokyo Midnight Saturated",
    "colors": {
        "editor.background": "#0a0a0d",
        "editor.foreground": "#a9b1d6",
        "editorCursor.foreground": "#7aa2f7",
        "editor.selectionBackground": "#1a1b2e",
        "editor.selectionForeground": "#c0caf5",
        
        "tab.activeBackground": "#0a0a0d",
        "tab.inactiveBackground": "#050507",
        "editorGroupHeader.tabsBackground": "#050507",
        "editorGroupHeader.noTabsBackground": "#050507",

        "notifications.background": "#050507",
        "notifications.foreground": "#a9b1d6",
        "notifications.border": "#1a1b2e",
        "notificationCenterHeader.background": "#050507",
        "notificationToast.border": "#1a1b2e",
        "button.background": "#4d8fff",
        "button.foreground": "#0a0a0d",
        "button.hoverBackground": "#7aa2f7",
        
        "terminal.background": "#050507",
        "terminal.foreground": "#a9b1d6",
        "terminalCursor.foreground": "#7aa2f7",
        "terminal.selectionBackground": "#1a1b2e",
        
        "terminal.ansiBlack": "#363b54",
        "terminal.ansiRed": "#ff3d6b",
        "terminal.ansiGreen": "#00d4a8",
        "terminal.ansiYellow": "#ffbe00",
        "terminal.ansiBlue": "#4d8fff",
        "terminal.ansiMagenta": "#d45aff",
        "terminal.ansiCyan": "#00d4ff",
        "terminal.ansiWhite": "#787c99",
        
        "terminal.ansiBrightBlack": "#363b54",
        "terminal.ansiBrightRed": "#ff3d6b",
        "terminal.ansiBrightGreen": "#00d4a8",
        "terminal.ansiBrightYellow": "#ffbe00",
        "terminal.ansiBrightBlue": "#4d8fff",
        "terminal.ansiBrightMagenta": "#d45aff",
        "terminal.ansiBrightCyan": "#00d4ff",
        "terminal.ansiBrightWhite": "#acb0d0",

        "quickInput.background": "#050507",
        "quickInput.foreground": "#a9b1d6",
        "quickInputList.focusBackground": "#1a1b2e",
        "quickInputList.focusForeground": "#c0caf5",
        "pickerGroup.border": "#1a1b2e",
        "pickerGroup.foreground": "#4d8fff",

        "panel.background": "#050507",
        "panel.border": "#050507",
        "panelTitle.activeForeground": "#a9b1d6",
        "panelTitle.inactiveForeground": "#787c99",
        "panelTitle.activeBorder": "#4d8fff",

        "input.background": "#050507",
        "input.foreground": "#a9b1d6",
        "input.border": "#1a1b2e",

        "activityBar.background": "#050507",
        "sideBar.background": "#050507",
        "sideBar.border": "#1a1b2e",
        "sideBarSectionHeader.background": "#050507",
        
        "titleBar.activeBackground": "#050507",
        "titleBar.inactiveBackground": "#050507",
        "titleBar.activeForeground": "#a9b1d6",
        "titleBar.inactiveForeground": "#787c99",
        "titleBar.border": "#1a1b2e",
        
        "statusBar.background": "#050507",
        "statusBar.noFolderBackground": "#050507",
        "statusBar.debuggingBackground": "#050507",
        "statusBar.foreground": "#a9b1d6"
    },
    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#787c99"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "string constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#a9b1d6"
            }
        },
        {
            "name": "Colors",
            "scope": [
                "constant.other.color"
            ],
            "settings": {
                "foreground": "#a9b1d6"
            }
        },
        {
            "name": "Invalid",
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#ff3d6b"
            }
        },
        {
            "name": "Keyword, Storage",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#d45aff"
            }
        },
        {
            "name": "Operator, Misc",
            "scope": [
                "keyword.control",
                "constant.other.color",
                "punctuation",
                "meta.tag",
                "punctuation.definition.tag",
                "punctuation.separator.inheritance.php",
                "punctuation.definition.tag.html",
                "punctuation.definition.tag.begin.html",
                "punctuation.definition.tag.end.html",
                "punctuation.section.embedded",
                "keyword.other.template",
                "keyword.other.substitution"
            ],
            "settings": {
                "foreground": "#00d4ff"
            }
        },
        {
            "name": "Tag",
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml",
                "markup.deleted.git_gutter"
            ],
            "settings": {
                "foreground": "#ff3d6b"
            }
        },
        {
            "name": "Function, Special Method",
            "scope": [
                "entity.name.function",
                "meta.function-call",
                "variable.function",
                "support.function",
                "keyword.other.special-method"
            ],
            "settings": {
                "foreground": "#4d8fff"
            }
        },
        {
            "name": "Block Level Variables",
            "scope": [
                "meta.block variable.other"
            ],
            "settings": {
                "foreground": "#ff3d6b"
            }
        },
        {
            "name": "Other Variable, String Link",
            "scope": [
                "support.other.variable",
                "string.other.link"
            ],
            "settings": {
                "foreground": "#ff3d6b"
            }
        },
        {
            "name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
            "scope": [
                "constant.numeric",
                "constant.language",
                "support.constant",
                "constant.character",
                "constant.escape",
                "variable.parameter",
                "keyword.other.unit",
                "keyword.other"
            ],
            "settings": {
                "foreground": "#ffbe00"
            }
        },
        {
            "name": "String, Symbols, Inherited Class, Markup Heading",
            "scope": [
                "string",
                "constant.other.symbol",
                "constant.other.key",
                "entity.other.inherited-class",
                "markup.heading",
                "markup.inserted.git_gutter",
                "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
            ],
            "settings": {
                "foreground": "#00d4a8"
            }
        },
        {
            "name": "Class, Support",
            "scope": [
                "entity.name",
                "support.type",
                "support.class",
                "support.other.namespace.use.php",
                "meta.use.php",
                "support.other.namespace.php",
                "markup.changed.git_gutter",
                "support.type.sys-types"
            ],
            "settings": {
                "foreground": "#ffbe00"
            }
        },
        {
            "name": "Entity Types",
            "scope": [
                "support.type"
            ],
            "settings": {
                "foreground": "#00d4ff"
            }
        },
        {
            "name": "CSS Class and Support",
            "scope": [
                "source.css support.type.property-name",
                "source.sass support.type.property-name",
                "source.scss support.type.property-name",
                "source.less support.type.property-name",
                "source.stylus support.type.property-name",
                "source.postcss support.type.property-name"
            ],
            "settings": {
                "foreground": "#00d4ff"
            }
        },
        {
            "name": "Sub-methods",
            "scope": [
                "entity.name.module.js",
                "variable.import.parameter.js",
                "variable.other.class.js"
            ],
            "settings": {
                "foreground": "#ff3d6b"
            }
        },
        {
            "name": "Language methods",
            "scope": [
                "variable.language"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#ff3d6b"
            }
        },
        {
            "name": "entity.name.method.js",
            "scope": [
                "entity.name.method.js"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#4d8fff"
            }
        },
        {
            "name": "meta.method.js",
            "scope": [
                "meta.class-method.js entity.name.function.js",
                "variable.function.constructor"
            ],
            "settings": {
                "foreground": "#4d8fff"
            }
        },
        {
            "name": "Attributes",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#d45aff"
            }
        },
        {
            "name": "HTML Attributes",
            "scope": [
                "text.html.basic entity.other.attribute-name.html",
                "text.html.basic entity.other.attribute-name"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#ffbe00"
            }
        },
        {
            "name": "CSS Classes",
            "scope": [
                "entity.other.attribute-name.class"
            ],
            "settings": {
                "foreground": "#ffbe00"
            }
        },
        {
            "name": "CSS ID's",
            "scope": [
                "source.sass keyword.control"
            ],
            "settings": {
                "foreground": "#4d8fff"
            }
        },
        {
            "name": "Inserted",
            "scope": [
                "markup.inserted"
            ],
            "settings": {
                "foreground": "#00d4a8"
            }
        },
        {
            "name": "Deleted",
            "scope": [
                "markup.deleted"
            ],
            "settings": {
                "foreground": "#ff3d6b"
            }
        },
        {
            "name": "Changed",
            "scope": [
                "markup.changed"
            ],
            "settings": {
                "foreground": "#d45aff"
            }
        },
        {
            "name": "Regular Expressions",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#00d4ff"
            }
        },
        {
            "name": "Escape Characters",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#00d4ff"
            }
        },
        {
            "name": "URL",
            "scope": [
                "*url*",
                "*link*",
                "*uri*"
            ],
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "name": "Decorators",
            "scope": [
                "tag.decorator.js entity.name.tag.js",
                "tag.decorator.js punctuation.definition.tag.js"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#4d8fff"
            }
        },
        {
            "name": "ES7 Bind Operator",
            "scope": [
                "source.js constant.other.object.key.js string.unquoted.label.js"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#ff3d6b"
            }
        },
